{
  "name": "mapitron-web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm run _cmake:configure",
    "start": "npm run _start:prefix -- \"npm run _cpp:watch:all\"",
    "start:nocpp": "vite",
    "start:novite": "npm run _cpp:watch:all",
    "start:debug": "npm run _cmake:build:debug && cnpm run _start:prefix -- \"npm run _cpp:watch:debug\"",
    "start:release": "npm run _cmake:build:release && npm run _start:prefix -- \"npm run _cpp:watch:release\"",
    "start:relwithdebinfo": "npm run _cmake:build:relwithdebinfo && npm run _start:prefix -- \"npm run _cpp:watch:relwithdebinfo\"",
    "start:minsizerel": "npm run _cmake:build:minsizerel && npm run _start:prefix -- \"npm run _cpp:watch:minsizerel\"",
    "_start:prefix": "concurrently -n vite,cpp -c cyan,magenta \"vite\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "TEST_BUILD=debug vitest",
    "test:ui": "vitest --ui",
    "test:debug": "TEST_BUILD=debug vitest",
    "test:release": "TEST_BUILD=release vitest",
    "test:relwithdebinfo": "TEST_BUILD=relwithdebinfo vitest",
    "test:minsizerel": "TEST_BUILD=minsizerel vitest",
    "prestart": "npm run _cmake:build:all",
    "prebuild": "npm run _cmake:build:all",
    "_cpp:watch:all": "npm run _cpp:watch:prefix -- \"npm run _cmake:build:all\"",
    "_cpp:watch:debug": "npm run _cpp:watch:prefix -- \"npm run _cmake:build:debug\"",
    "_cpp:watch:release": "npm run _cpp:watch:prefix -- \"npm run _cmake:build:release\"",
    "_cpp:watch:relwithdebinfo": "npm run _cpp:watch:prefix -- \"npm run _cmake:build:relwithdebinfo\"",
    "_cpp:watch:minsizerel": "npm run _cpp:watch:prefix -- \"npm run _cmake:build:minsizerel\"",
    "_cpp:watch:prefix": "chokidar \"../../src/**/*.{cpp,hpp}\" \"../../include/**/*.hpp\" -c",
    "_cmake:configure": "cd ../../.. && cmake --preset targ-emscripten-Debug && cmake --preset targ-emscripten-Release && cmake --preset targ-emscripten-RelWithDebInfo && cmake --preset targ-emscripten-MinSizeRel",
    "_cmake:build:all": "npm run _cmake:build:debug && npm run _cmake:build:release && npm run _cmake:build:relwithdebinfo && npm run _cmake:build:minsizerel",
    "_cmake:build:debug": "npm run _cmake:build:prefix -- --preset targ-emscripten-Debug",
    "_cmake:build:release": "npm run _cmake:build:prefix -- --preset targ-emscripten-Release",
    "_cmake:build:relwithdebinfo": "npm run _cmake:build:prefix -- --preset targ-emscripten-RelWithDebInfo",
    "_cmake:build:minsizerel": "npm run _cmake:build:prefix -- --preset targ-emscripten-MinSizeRel",
    "_cmake:build:prefix": "cd ../../.. && cmake --build --target mapitron-wasm"
  },
  "dependencies": {
    "mapitron": "file:../../packages/web/mapitron"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.1.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
