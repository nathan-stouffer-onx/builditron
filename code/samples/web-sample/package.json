{
  "name": "mapitron-web",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm run _cmake:configure",
    "start": "concurrently -n vite,cpp -c cyan,magenta \"vite\" \"npm run _cpp:watch\"",
    "start:nocpp": "vite",
    "start:novite": "npm run _cpp:watch",
    "start:debug": "npm run _cmake:build:debug && concurrently -n vite,cpp -c cyan,magenta \"vite\" \"npm run _cpp:watch:debug\"",
    "start:release": "npm run _cmake:build:release && concurrently -n vite,cpp -c cyan,magenta \"vite\" \"npm run _cpp:watch:release\"",
    "start:relwithdebinfo": "npm run _cmake:build:relwithdebinfo && concurrently -n vite,cpp -c cyan,magenta \"vite\" \"npm run _cpp:watch:relwithdebinfo\"",
    "start:minsizerel": "npm run _cmake:build:minsizerel && concurrently -n vite,cpp -c cyan,magenta \"vite\" \"npm run _cpp:watch:minsizerel\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:debug": "npm run _cmake:build:debug && TEST_BUILD=debug vitest",
    "test:release": "npm run _cmake:build:release && TEST_BUILD=release vitest",
    "test:relwithdebinfo": "npm run _cmake:build:relwithdebinfo && TEST_BUILD=relwithdebinfo vitest",
    "test:minsizerel": "npm run _cmake:build:minsizerel && TEST_BUILD=minsizerel vitest",
    "prestart": "npm run _cmake:build:debug",
    "prebuild": "npm run _cmake:build:debug && npm run _cmake:build:release && npm run _cmake:build:relwithdebinfo && npm run _cmake:build:minsizerel",
    "_cpp:watch": "npm run _cpp:watch:debug",
    "_cpp:watch:debug": "chokidar \"../../src/**/*.{cpp,hpp}\" \"../../include/**/*.hpp\" -c \"npm run _cmake:build:debug\"",
    "_cpp:watch:release": "chokidar \"../../src/**/*.{cpp,hpp}\" \"../../include/**/*.hpp\" -c \"npm run _cmake:build:release\"",
    "_cpp:watch:relwithdebinfo": "chokidar \"../../src/**/*.{cpp,hpp}\" \"../../include/**/*.hpp\" -c \"npm run _cmake:build:relwithdebinfo\"",
    "_cpp:watch:minsizerel": "chokidar \"../../src/**/*.{cpp,hpp}\" \"../../include/**/*.hpp\" -c \"npm run _cmake:build:minsizerel\"",
    "_cmake:configure": "cd ../../.. && cmake --preset targ-emscripten-Debug && cmake --preset targ-emscripten-Release && cmake --preset targ-emscripten-RelWithDebInfo && cmake --preset targ-emscripten-MinSizeRel",
    "_cmake:build:debug": "cd ../../.. && cmake --build --preset targ-emscripten-Debug --target mapitron-wasm",
    "_cmake:build:release": "cd ../../.. && cmake --build --preset targ-emscripten-Release --target mapitron-wasm",
    "_cmake:build:relwithdebinfo": "cd ../../.. && cmake --build --preset targ-emscripten-RelWithDebInfo --target mapitron-wasm",
    "_cmake:build:minsizerel": "cd ../../.. && cmake --build --preset targ-emscripten-MinSizeRel --target mapitron-wasm",
    "_cmake:build": "npm run _cmake:build:debug && npm run _cmake:build:release"
  },
  "dependencies": {
    "mapitron": "file:../../packages/web/mapitron"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/ui": "^2.1.0",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
