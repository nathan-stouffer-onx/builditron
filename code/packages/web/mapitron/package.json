{
  "name": "mapitron",
  "version": "0.0.0",
  "description": "WebAssembly-powered map rendering library",
  "type": "module",
  "main": "./src/MinSizeRel/mapitron.js",
  "types": "./src/mapitron.d.ts",
  "exports": {
    ".": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/MinSizeRel/mapitron.js"
    },
    "./Debug": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/Debug/mapitron.js"
    },
    "./Release": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/Release/mapitron.js"
    },
    "./RelWithDebInfo": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/RelWithDebInfo/mapitron.js"
    },
    "./MinSizeRel": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/MinSizeRel/mapitron.js"
    },
    "./Debug/mapitron.wasm": "./src/Debug/mapitron.wasm",
    "./Release/mapitron.wasm": "./src/Release/mapitron.wasm",
    "./RelWithDebInfo/mapitron.wasm": "./src/RelWithDebInfo/mapitron.wasm",
    "./MinSizeRel/mapitron.wasm": "./src/MinSizeRel/mapitron.wasm"
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "npm run configure && npm run build:all",
    "build:all": "npm run build:Debug && npm run build:Release && npm run build:RelWithDebInfo && npm run build:MinSizeRel",
    "build:Debug": "npm run _build:prefix -- --preset dest-emscripten-Debug",
    "build:Release": "npm run _build:prefix -- --preset dest-emscripten-Release",
    "build:RelWithDebInfo": "npm run _build:prefix -- --preset dest-emscripten-RelWithDebInfo",
    "build:MinSizeRel": "npm run _build:prefix -- --preset dest-emscripten-MinSizeRel",
    "configure": "cd ../../../.. && cmake --preset dest-emscripten",
    "_build:prefix": "cd ../../../.. && cmake --build"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "maps",
    "graphics",
    "emscripten"
  ],
  "author": "",
  "license": "MIT"
}
