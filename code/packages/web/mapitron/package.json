{
  "name": "mapitron",
  "version": "0.0.0",
  "description": "WebAssembly-powered map rendering library",
  "type": "module",
  "main": "./src/minsizerel/mapitron.js",
  "types": "./src/mapitron.d.ts",
  "exports": {
    ".": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/minsizerel/mapitron.js"
    },
    "./debug": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/debug/mapitron.js"
    },
    "./release": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/release/mapitron.js"
    },
    "./relwithdebinfo": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/relwithdebinfo/mapitron.js"
    },
    "./minsizerel": {
      "types": "./src/mapitron.d.ts",
      "import": "./src/minsizerel/mapitron.js"
    },
    "./debug/mapitron.wasm": "./src/debug/mapitron.wasm",
    "./release/mapitron.wasm": "./src/release/mapitron.wasm",
    "./relwithdebinfo/mapitron.wasm": "./src/relwithdebinfo/mapitron.wasm",
    "./minsizerel/mapitron.wasm": "./src/minsizerel/mapitron.wasm"
  },
  "files": [
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "build:debug": "npm run _cmake:build:prefix -- --preset targ-emscripten-Debug",
    "build:release": "npm run _cmake:build:prefix -- --preset targ-emscripten-Release",
    "build:relwithdebinfo": "npm run _cmake:build:prefix -- --preset targ-emscripten-RelWithDebInfo",
    "build:minsizerel": "npm run _cmake:build:prefix -- --preset targ-emscripten-MinSizeRel",
    "build:all": "npm run build:debug && npm run build:release && npm run build:relwithdebinfo && npm run build:minsizerel",
    "prepublishOnly": "npm run build:all",
    "_cmake:build:prefix": "cd ../../.. && cmake --build"
  },
  "keywords": [
    "webassembly",
    "wasm",
    "maps",
    "graphics",
    "emscripten"
  ],
  "author": "",
  "license": "MIT"
}
