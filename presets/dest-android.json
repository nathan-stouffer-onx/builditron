{
  "version": 8,
  "include": ["base.json"],
  "configurePresets": [
    {
      "name": "dest-deps-android",
      "hidden": true,
      "inherits": "dest-base",
      "environment": {
        "ANDROID_NDK_ROOT": "${sourceDir}/code/deps/android-ndk/android-ndk-r27"
      },
      "cacheVariables": {
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "$env{ANDROID_NDK_ROOT}/build/cmake/android.toolchain.cmake",
        "ANDROID_PLATFORM": "android-24"
      }
    },
    {
      "name": "dest-deps-android-arm64",
      "hidden": true,
      "inherits": "dest-deps-android",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-android",
        "ANDROID_ABI": "arm64-v8a"
      }
    },
    {
      "name": "dest-deps-android-x86_64",
      "hidden": true,
      "inherits": "dest-deps-android",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-android",
        "ANDROID_ABI": "x86_64"
      }
    },
    {
      "name": "dest-env-android-arm64",
      "hidden": true,
      "inherits": "dest-deps-android-arm64",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel",
        "CMAKE_DEFAULT_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dest-env-android-x86_64",
      "hidden": true,
      "inherits": "dest-deps-android-x86_64",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel",
        "CMAKE_DEFAULT_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dest-android-arm64",
      "inherits": "dest-env-android-arm64",
      "cacheVariables": {
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/lib"
      }
    },
    {
      "name": "dest-android-x86_64",
      "inherits": "dest-env-android-x86_64",
      "cacheVariables": {
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/build/${presetName}/lib"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dest-android-arm64-Debug",
      "configurePreset": "dest-android-arm64",
      "configuration": "Debug"
    },
    {
      "name": "dest-android-arm64-RelWithDebInfo",
      "configurePreset": "dest-android-arm64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "dest-android-arm64-Release",
      "configurePreset": "dest-android-arm64",
      "configuration": "Release"
    },
    {
      "name": "dest-android-arm64-MinSizeRel",
      "configurePreset": "dest-android-arm64",
      "configuration": "MinSizeRel"
    },
    {
      "name": "dest-android-x86_64-Debug",
      "configurePreset": "dest-android-x86_64",
      "configuration": "Debug"
    },
    {
      "name": "dest-android-x86_64-RelWithDebInfo",
      "configurePreset": "dest-android-x86_64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "dest-android-x86_64-Release",
      "configurePreset": "dest-android-x86_64",
      "configuration": "Release"
    },
    {
      "name": "dest-android-x86_64-MinSizeRel",
      "configurePreset": "dest-android-x86_64",
      "configuration": "MinSizeRel"
    }
  ]
}
