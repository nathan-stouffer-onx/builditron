{
  "version": 8,
  "include": ["base.json"],
  "configurePresets": [
    {
      "name": "dest-deps-mac",
      "hidden": true,
      "inherits": "dest-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "arm64-osx"
      }
    },
    {
      "name": "dest-env-mac-clang-xcode",
      "hidden": true,
      "inherits": "dest-deps-mac",
      "generator": "Xcode",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "dest-env-mac-clang-ninja",
      "hidden": true,
      "inherits": "dest-deps-mac",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "dest-mac-xcode",
      "inherits": "dest-env-mac-clang-xcode"
    },
    {
      "name": "dest-mac-ninja",
      "inherits": "dest-env-mac-clang-ninja"
    }
  ],
  "buildPresets": [
    {
      "name": "dest-mac-xcode-Debug",
      "configurePreset": "dest-mac-xcode",
      "configuration": "Debug"
    },
    {
      "name": "dest-mac-xcode-RelWithDebInfo",
      "configurePreset": "dest-mac-xcode",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "dest-mac-xcode-Release",
      "configurePreset": "dest-mac-xcode",
      "configuration": "Release"
    },
    {
      "name": "dest-mac-xcode-MinSizeRel",
      "configurePreset": "dest-mac-xcode",
      "configuration": "MinSizeRel"
    },
    {
      "name": "dest-mac-ninja-Debug",
      "configurePreset": "dest-mac-ninja",
      "configuration": "Debug"
    },
    {
      "name": "dest-mac-ninja-RelWithDebInfo",
      "configurePreset": "dest-mac-ninja",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "dest-mac-ninja-Release",
      "configurePreset": "dest-mac-ninja",
      "configuration": "Release"
    },
    {
      "name": "dest-mac-ninja-MinSizeRel",
      "configurePreset": "dest-mac-ninja",
      "configuration": "MinSizeRel"
    }
  ]
}
