{
  "version": 8,
  "include": ["base.json"],
  "configurePresets": [
    {
      "name": "dest-deps-emscripten",
      "hidden": true,
      "inherits": "dest-base",
      "environment": {
        "EMSDK": "${sourceDir}/code/deps/emsdk",
        "EMSCRIPTEN_ROOT": "${sourceDir}/code/deps/emsdk/upstream/emscripten",
        "EMSCRIPTEN": "${sourceDir}/code/deps/emsdk/upstream/emscripten"
      },
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "wasm32-emscripten",
        "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${sourceDir}/code/deps/emsdk/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
      }
    },
    {
      "name": "dest-env-emscripten",
      "hidden": true,
      "inherits": "dest-deps-emscripten",
      "generator": "Ninja Multi-Config",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo;MinSizeRel",
        "CMAKE_DEFAULT_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "dest-emscripten",
      "inherits": "dest-env-emscripten"
    }
  ],
  "buildPresets": [
    {
      "name": "dest-emscripten-Debug",
      "configurePreset": "dest-emscripten",
      "configuration": "Debug"
    },
    {
      "name": "dest-emscripten-RelWithDebInfo",
      "configurePreset": "dest-emscripten",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "dest-emscripten-Release",
      "configurePreset": "dest-emscripten",
      "configuration": "Release"
    },
    {
      "name": "dest-emscripten-MinSizeRel",
      "configurePreset": "dest-emscripten",
      "configuration": "MinSizeRel"
    }
  ]
}
