{
  "version": 8,
  "include": ["base.json"],
  "configurePresets": [
    {
      "name": "host-deps-win",
      "hidden": true,
      "inherits": "host-base",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "host-env-win-msvc-vs",
      "hidden": true,
      "inherits": "host-deps-win",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      }
    },
    {
      "name": "host-win",
      "inherits": "host-env-win-msvc-vs"
    },
    {
      "name": "host-win-Debug",
      "inherits": "host-win"
    },
    {
      "name": "host-win-RelWithDebInfo",
      "inherits": "host-win"
    },
    {
      "name": "host-win-Release",
      "inherits": "host-win"
    },
    {
      "name": "host-win-MinSizeRel",
      "inherits": "host-win"
    }
  ],
  "buildPresets": [
    {
      "name": "host-win-Debug",
      "configurePreset": "host-win",
      "configuration": "Debug"
    },
    {
      "name": "host-win-RelWithDebInfo",
      "configurePreset": "host-win",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "host-win-Release",
      "configurePreset": "host-win",
      "configuration": "Release"
    },
    {
      "name": "host-win-MinSizeRel",
      "configurePreset": "host-win",
      "configuration": "MinSizeRel"
    }
  ]
}
